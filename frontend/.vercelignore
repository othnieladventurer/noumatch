# Ignore everything in /api folder
api/
/api/

# Ignore all Python files anywhere
**/*.py
**/*.pyc
**/__pycache__/
**/requirements.txt
**/Pipfile
**/Pipfile.lock
**/manage.py
**/*.sqlite3

# Ignore backend virtual environments
**/venv/
**/env/
**/myenv/
**/.venv/

# Keep only frontend files
!src/
!public/
!index.html
!package.json
!package-lock.json
!vercel.json
!.vercelignore
!vite.config.js